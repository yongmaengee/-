# 사용 시: cp .env.example .env  →  .env 에 실제 키 입력 후 source ./.env 또는 export
# .env는 gitignore 됨

# 기상청 공공데이터포털 일반인증키 (data.go.kr)
export KMA_KEY=""

# Slack Incoming Webhook URL (api.slack.com/apps → Incoming Webhooks)
export SLACK_WEBHOOK=""

# (선택) chat:write 스코프 시
export SLACK_TOKEN=""
export SLACK_CHANNEL="#general"

# 운영 토글
export USE_KMA_LIVE=1
export USE_SLACK_LIVE=1
